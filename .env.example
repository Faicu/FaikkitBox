# Copiază acest fișier ca ".env" și completează valorile reale.
# NU comite niciodată fișierul ".env" în git.

# --- Admin login (dashboard) ---
ADMIN_USER=admin
ADMIN_PASS=schimba-asta-cu-o-parola-puternica
# Secret pentru sesiunea de admin — minim 32 caractere aleatorii.
# Generează unul cu: openssl rand -hex 32
SESSION_SECRET=

# --- Plex ---
PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=

# --- Immich ---
IMMICH_URL=http://127.0.0.1:2283
IMMICH_API_KEY=

# --- qBittorrent (WebUI) ---
QBIT_URL=http://127.0.0.1:8080
QBIT_USERNAME=
QBIT_PASSWORD=

# --- Glances a fost eliminat — statisticile de sistem se citesc acum direct pe host ---

# --- Cai catre docker-compose ale serviciilor Docker (pentru butoanele de restart din dashboard) ---
# Implicit: /root/plex/docker-compose.yml si /root/immich-app/docker-compose.yml
# Decomenteaza doar daca instalarea ta foloseste alte cai.
# PLEX_COMPOSE_FILE=/root/plex/docker-compose.yml
# IMMICH_COMPOSE_FILE=/root/immich-app/docker-compose.yml

# --- Agentul separat (agent/) a fost eliminat — comenzile ruleaza acum local ---

# --- Server ---
PORT=3000
NODE_ENV=production
